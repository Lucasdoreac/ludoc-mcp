{
  "$schema": "https://registry.modelcontextprotocol.io/schema/v1",
  "namespace": "mauidevtools",
  "version": "1.0.0",
  "description": "MCP pack para desenvolvimento .NET MAUI — disciplina PDM",
  "servers": [
    {
      "name": "repomix",
      "description": "Empacota o projeto inteiro em contexto único para análise por IA",
      "source": {
        "type": "github",
        "url": "https://github.com/yamadashy/repomix"
      },
      "install": {
        "type": "stdio",
        "command": "bunx",
        "args": ["repomix", "--mcp"]
      },
      "tags": ["codebase", "context", "análise"]
    },
    {
      "name": "context7",
      "description": "Documentação atualizada de .NET, MAUI, NuGet e outras libs injetada no contexto",
      "source": {
        "type": "github",
        "url": "https://github.com/upstash/context7"
      },
      "install": {
        "type": "stdio",
        "command": "bunx",
        "args": ["-y", "@upstash/context7-mcp@latest"]
      },
      "tags": ["docs", "dotnet", "maui", "nuget"]
    },
    {
      "name": "sequential-thinking",
      "description": "Resolução de problemas em cadeia de raciocínio estruturado",
      "source": {
        "type": "github",
        "url": "https://github.com/modelcontextprotocol/servers",
        "path": "src/sequentialthinking"
      },
      "install": {
        "type": "stdio",
        "command": "bunx",
        "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
      },
      "tags": ["reasoning", "planning"]
    },
    {
      "name": "microsoft-learn",
      "description": "Documentação oficial .NET / MAUI / XAML direto do Microsoft Learn",
      "source": {
        "type": "http",
        "url": "https://learn.microsoft.com/api/mcp"
      },
      "install": {
        "type": "http",
        "url": "https://learn.microsoft.com/api/mcp"
      },
      "tags": ["docs", "dotnet", "maui", "xaml", "microsoft"]
    },
    {
      "name": "nuget",
      "description": "Busca pacotes NuGet com tipos e interfaces reais — evita alucinação de APIs",
      "source": {
        "type": "dotnet-tool",
        "package": "NugetMcpServer"
      },
      "install": {
        "type": "stdio",
        "command": "NugetMcpServer"
      },
      "tags": ["nuget", "dotnet", "packages"]
    },
    {
      "name": "semgrep",
      "description": "Análise estática de código — bugs, segurança e qualidade",
      "source": {
        "type": "github",
        "url": "https://github.com/semgrep/semgrep"
      },
      "install": {
        "type": "stdio",
        "command": "uvx",
        "args": ["semgrep-mcp"]
      },
      "tags": ["segurança", "static-analysis", "qualidade"]
    },
    {
      "name": "ast-grep",
      "description": "Busca estrutural no código por padrões de sintaxe (não só texto)",
      "source": {
        "type": "github",
        "url": "https://github.com/ast-grep/ast-grep-mcp"
      },
      "install": {
        "type": "stdio",
        "command": "uvx",
        "args": ["--from", "git+https://github.com/ast-grep/ast-grep-mcp", "ast-grep-server"]
      },
      "tags": ["ast", "busca", "refactoring"]
    }
  ]
}
