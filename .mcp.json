{
  "_info": "MauiDevTools — config para VS 2022/2026. Copie para ~/.mcp.json ou use install-to-vs.ps1",
  "servers": {
    "repomix": {
      "type": "stdio",
      "command": "bunx",
      "args": ["repomix", "--mcp"]
    },
    "context7": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "nuget": {
      "type": "stdio",
      "command": "DimonSmart.NugetMcpServer"
    },
    "semgrep": {
      "type": "stdio",
      "command": "uvx",
      "args": ["semgrep-mcp"]
    },
    "ast-grep": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/ast-grep/ast-grep-mcp", "ast-grep-server"]
    }
  }
}
