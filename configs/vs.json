{
  "_info": "MauiDevTools — config para Visual Studio 2022/2026. Copie para ~/.mcp.json",
  "servers": {
    "repomix": {
      "type": "stdio",
      "command": "bunx",
      "args": ["repomix", "--mcp"]
    },
    "context7": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "browser-tools": {
      "type": "stdio",
      "command": "bunx",
      "args": ["@agentdeskai/browser-tools-mcp@latest"]
    },
    "semgrep": {
      "type": "stdio",
      "command": "uvx",
      "args": ["semgrep-mcp"]
    },
    "ast-grep": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/ast-grep/ast-grep-mcp", "ast-grep-server"]
    }
  }
}
